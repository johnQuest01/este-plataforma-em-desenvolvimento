generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Utilizador da plataforma: comprador (`role = customer`) ou vendedor (`role = seller`).
/// PF/PJ distinguem-se por `documentType` (CPF/CNPJ) e `document` (único).
///
/// ── CLIENTES ───────────────────────────────────────────────────────────────────
///   role = "customer" → compas via `orders`, favoritos via `favoriteProducts`,
///   atividades via `activityLogs`, vendedora indicadora via `referredBySeller`.
///
/// ── VENDEDORES AUTORIZADOS ─────────────────────────────────────────────────────
///   role = "seller" → estoque pessoal via `sellerInventory`, loja via `stores`,
///   clientes indicados via `referredClients`, slug de loja via `sellerSlug`.
///
/// ── ADMIN ──────────────────────────────────────────────────────────────────────
///   role = "admin" → gerencia catálogo global Maryland via `stores`.
model User {
  id                 String          @id @default(cuid())
  email              String?         @unique
  document           String          @unique
  documentType       String          @default("CPF")
  passwordHash       String          @default("")
  name               String?
  whatsapp           String?
  address            String?
  street             String?
  addressNumber      String?
  addressComplement  String?
  district           String?
  city               String?
  state              String?
  postalCode         String?
  profilePictureUrl  String?
  backgroundImageUrl String?
  /// `customer` = comprador; `seller` = vendedor autorizado; `admin` = admin Maryland 0000.
  role               String          @default("customer")

  // ── Dados exclusivos de Vendedor Autorizado ──────────────────────────────────
  /// Slug único da loja da vendedora (ex: "bruna-maryland-x7k") — gerado automaticamente
  sellerSlug         String?         @unique
  /// Vendedor que indicou este cliente (via link /dashboard?seller=[slug])
  referredBySellerId String?
  referredBySeller   User?           @relation("SellerReferrals", fields: [referredBySellerId], references: [id], onDelete: SetNull)
  /// Clientes que o vendedor indicou
  referredClients    User[]          @relation("SellerReferrals")
  /// Estoque pessoal do vendedor
  sellerInventory    SellerInventoryItem[]
  /// Loja(s) do vendedor / admin
  stores             Store[]

  // ── Dados exclusivos de Cliente ───────────────────────────────────────────────
  /// Histórico de compras do cliente (pedidos vinculados)
  orders             Order[]         @relation("CustomerOrders")
  /// Produtos favoritados pelo cliente
  favoriteProducts   Product[]       @relation("UserFavorites")

  // ── Dados compartilhados ──────────────────────────────────────────────────────
  isTwoFactorEnabled Boolean         @default(false)
  paymentMethods     PaymentMethod[]
  /// Log de atividades do usuário (login, compra, favorito, etc.)
  activityLogs       ActivityLog[]

  /// Pedidos gerados por clientes que o vendedor indicou (via link de loja)
  referredOrders     Order[]         @relation("OrderReferrals")

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([role])
  @@index([referredBySellerId])
}

// NOVO MODELO: Métodos de Pagamento
model PaymentMethod {
  id              String   @id @default(cuid())
  institutionName String
  accountType     String   /// Ex: 'Débito', 'Crédito', 'Pix'
  cardholderName  String
  cardNumber      String   /// ATENÇÃO: Em produção, armazenar apenas token ou encriptado
  expirationDate  String
  securityCode    String   /// ATENÇÃO: Violação PCI-DSS se armazenado em plain text em produção
  balance         Decimal? @db.Decimal(10, 2)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Store {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  nicheType        String            @default("clothing")
  features         Json              @default("{}")
  layoutConfig     Json?             @default("[]")
  themeConfig      Json?             @default("{}")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id])
  products         Product[]
  orders           Order[]
  productionItems  ProductionItem[]
  productionOrders ProductionOrder[]
}

model Product {
  id              String           @id @default(cuid())
  name            String
  description     String?
  price           Decimal          @db.Decimal(10, 2)
  reference       String?
  category        String?
  imageColor      String?
  imageUrl        String?
  tags            String[]
  isVisible       Boolean          @default(true)
  stock           Int              @default(0)
  
  // NOVOS CAMPOS ADICIONADOS
  isPreOrder      Boolean          @default(false)
  isLive          Boolean          @default(false)
  favoritedBy     User[]           @relation("UserFavorites")

  variants        ProductVariant[]
  storeId         String
  store           Store            @relation(fields: [storeId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  orderItems      OrderItem[]
  productionItems ProductionItem[]
  /// Estoques pessoais dos vendedores que pegaram este produto
  sellerInventory SellerInventoryItem[]
  
  @@index([reference])
  @@index([category])
}

model ProductVariant {
  id        String   @id @default(cuid())
  name      String
  sku       String?  @unique
  price     Decimal? @db.Decimal(10, 2)
  stock     Int      @default(0)
  images    String[]
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductionOrder {
  id          String      @id @default(cuid())
  productName String
  image       String      @db.Text
  status      String      @default("PENDING")
  storeId     String?
  store       Store?      @relation(fields: [storeId], references: [id])
  variations  Variation[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Variation {
  id                String          @id @default(cuid())
  name              String
  category          String?
  color             String
  size              String
  quantity          Int             @map("qty")
  stockLocations    String[]
  images            String[]
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
}

model ProductionItem {
  id          String     @id @default(cuid())
  status      String     @default("PENDING")
  priority    Int        @default(0)
  notes       String?
  storeId     String
  store       Store      @relation(fields: [storeId], references: [id])
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  orderItemId String?    @unique
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  status        String      @default("PENDING")
  total         Decimal     @db.Decimal(10, 2)
  customerName  String?
  customerPhone String?

  /// Cliente que realizou a compra (null = venda no balcão/POS sem cadastro)
  customerId    String?
  customer      User?       @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: SetNull)

  /// Vendedor autorizado que indicou este cliente (via link de loja)
  referredBySellerId String?
  referredBySeller   User?  @relation("OrderReferrals", fields: [referredBySellerId], references: [id], onDelete: SetNull)

  storeId       String
  store         Store       @relation(fields: [storeId], references: [id])
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt

  @@index([customerId])
  @@index([referredBySellerId])
  @@index([storeId])
}

model OrderItem {
  id         String          @id @default(cuid())
  quantity   Int
  price      Decimal         @db.Decimal(10, 2)
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id])
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  production ProductionItem?
}

/// Registro de atividades de cada usuário (cliente ou vendedor).
/// Usado para: histórico de compras, logins, favoritos, vendas, etc.
model ActivityLog {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Tipo da ação: "LOGIN" | "PURCHASE" | "SALE" | "FAVORITE" | "UNFAVORITE" |
  ///               "VIEW_PRODUCT" | "REGISTER" | "SELLER_LINK_SHARED"
  action      String

  /// Descrição legível para o usuário (ex: "Comprou Calça Jeans Azul - 2x")
  description String?

  /// Dados extras em JSON (ex: { "productId": "...", "quantity": 2, "total": 99.90 })
  metadata    Json?

  /// ID do produto relacionado (se aplicável)
  productId   String?

  /// ID do pedido relacionado (se aplicável)
  orderId     String?

  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
}

model GuardianConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model UIConfig {
  id              String   @id @default(cuid())
  pageSlug        String   @unique
  layout          Json     @default("[]")
  dashboardLayout Json?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model Banner {
  id          String   @id @default(cuid())
  title       String
  mediaType   String
  mediaUrl    String   @db.Text
  aspectRatio String
  orderIndex  Int      @default(0)
  isVisible   Boolean  @default(true)
  linkUrl     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([orderIndex])
  @@index([isVisible])
}

model DevelopmentCardPercentage {
  id               String    @id @default("development-card-single-record")
  percentage       Int       @default(69)
  isManual         Boolean   @default(false)
  lastManualUpdate DateTime?
  lastAutoUpdate   DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())
}

model AdminAccess {
  id             String    @id @default("admin-access-single-record")
  passwordHash   String
  isUnlocked     Boolean   @default(false)
  lastAccess     DateTime?
  accessCount    Int       @default(0)
  buttonPosition Json?     @default("{\"x\": 0, \"y\": 0}")
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())
}

/// Configurações visuais globais do app — controladas pelo painel "Mão de Deus".
/// Um único registro (id = "global") é sempre lido/gravado.
model AppConfig {
  id String @id @default("global")

  // ── Banner ────────────────────────────────────────────────────────────────
  /// Aspect ratio do banner: "16/9" | "16/7" | "16/5" | "square"
  bannerAspectRatio   String  @default("16/7")
  /// Altura fixa em px (0 = usar aspect ratio)
  bannerHeightPx      Int     @default(0)
  /// Remover todas as bordas do banner
  bannerNoBorder      Boolean @default(false)
  /// Raio das bordas do banner (px)
  bannerBorderRadius  Int     @default(0)

  // ── Categorias / Reels ────────────────────────────────────────────────────
  /// Diâmetro dos círculos de categoria (px)
  categoriesCircleSize Int    @default(56)
  /// Mostrar label abaixo do círculo
  categoriesShowLabel  Boolean @default(true)
  /// Tamanho do texto do label (px)
  categoriesLabelSize  Int    @default(10)

  // ── Cards de produto ──────────────────────────────────────────────────────
  /// Largura dos cards na grade principal (px)
  productCardWidth     Int    @default(120)
  /// Altura da imagem nos cards (px)
  productCardImageHeight Int  @default(120)
  /// Altura mínima do card branco abaixo da imagem (px)
  productCardInfoHeight  Int  @default(80)

  // ── Notas do administrador ────────────────────────────────────────────────
  /// Última nota escrita pelo admin no campo de notificação
  adminNote            String @default("")

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model FormVideoConfig {
  id                 String   @id @default("global-video-config")
  videoUrl           String   @default("") @db.Text
  cloudinaryPublicId String   @default("")
  metadata           Json?
  isActive           Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

/// Catálogo global Maryland — gerenciado apenas pelo Admin 0000.
/// Vendedores consultam este catálogo e adicionam itens ao seu estoque pessoal.
model MarylandCatalogProduct {
  id           String   @id @default(cuid())
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  reference    String?
  category     String?
  imageUrl     String?
  totalStock   Int      @default(0)
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([isAvailable])
}

/// Estoque pessoal de cada vendedor autorizado.
/// Cada linha representa (vendedor, produto, variação) → quantidade reservada.
/// variantId = "" significa "produto sem variação específica".
model SellerInventoryItem {
  id          String   @id @default(cuid())
  quantity    Int      @default(0)
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// ID da variação específica escolhida (string vazia = sem variação)
  variantId   String   @default("")
  /// Label legível: "Azul | M | Aberto"
  variantName String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sellerId, productId, variantId])
  @@index([sellerId])
}