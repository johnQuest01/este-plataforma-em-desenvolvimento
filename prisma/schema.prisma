  if (type.includes("prisma")) return <Database size={16} className={cn("text-cyan-400", className)} />;
  return <FileCode size={16} className={cn("text-zinc-500", className)} />;
};


// --- COMPONENTE DO CARD DE ARQUIVO (Compacto) ---
const FileCard = ({
  node,
  isSelected,
  hasChildren,
  onClick
}: {
  node: FileNode,
  isSelected: boolean,
  hasChildren: boolean,
  onClick: () => void
}) => {
  return (
