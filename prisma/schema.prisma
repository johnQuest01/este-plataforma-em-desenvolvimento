      </div>


      {metrics.isResponsiveIssue && (
        <div className="m-6 p-4 bg-red-500/5 border border-red-500/20 rounded-2xl flex items-center gap-4 animate-pulse">
          <AlertTriangle size={20} className="text-red-500" />
