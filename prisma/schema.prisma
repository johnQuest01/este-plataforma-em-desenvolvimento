        {/* Cabeçalho da Análise */}
        <div>
          <div className="flex items-center gap-2 mb-2">
            <div className="bg-indigo-500/10 p-1.5 rounded-lg border border-indigo-500/20">
               <Lightbulb size={14} className="text-indigo-400" />
