      */}
      {isDevelopmentEnvironment && (
        <>
          <GlobalGuardianObserver />
          <MasterGuardianDashboard />
        </>
      )}
    </>
  );
}

// ✅ Exportação com Etiqueta Inteligente e Metadados
export const RootLayoutShell = withGuardian(
  RootLayoutShellBase,
  "components/layouts/RootLayoutShell.tsx",
