                    <img 
                        src={item.productImage} 
                        alt={item.productName} 
                        className="w-full h-full object-cover" 
                    />
                    <div className="absolute bottom-0 right-0 bg-blue-600 text-white text-[10px] font-bold px-2 py-1 rounded-tl-md">
