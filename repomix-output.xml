            </div>

            {/* --- RODAPÉ INFO --- */}
            <div className="absolute bottom-0 w-full p-5 pb-8 flex flex-col gap-4 z-20 pointer-events-none">
                <div className="pointer-events-auto text-left px-1 animate-in slide-in-from-bottom-4 duration-500">
