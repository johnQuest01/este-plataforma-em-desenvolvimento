        break;

      default:
        console.log(`Ação: ${action}`);
    }
  };

  const handleProductRegister = (data: { image?: string }) => {
    if (data.image) {
      setBlocks(currentBlocks =>
        currentBlocks.map(block => {
          if (block.type === 'inventory-feature') {
            return {
              ...block,
              data: { ...block.data, boxImage: data.image }
            };
          }
          return block;
        })
      );
