  },
  transition: { 
    repeat: Infinity, 
    duration: 5,
    // CORREÇÃO: 'as const' garante que o TS entenda que é um Easing válido, não uma string qualquer
    ease: "easeInOut" as const 
  }
};

export const JeansHeader = () => {
